# ============================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# ============================================
# Copy this file to .env and update with your actual values

# ============================================
# SUPABASE CONFIGURATION
# ============================================
VITE_SUPABASE_URL=https://slfxozmbwogpisxeltty.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ============================================
# DOMAIN CONFIGURATION - CRITICAL FOR ONBOARDING
# ============================================
# 
# PRODUCTION DEPLOYMENT CHECKLIST:
# 1. Deploy to Vercel first
# 2. Test with Vercel URL (should work immediately)
# 3. Add custom domain in Vercel dashboard
# 4. Wait for SSL certificate to be issued
# 5. Test custom domain with https://
# 6. Only then update these URLs to custom domain
#
# IMPORTANT: Until SSL is ready, use Vercel URL

# Primary production URL
# Use Vercel URL until custom domain SSL is confirmed working
VITE_APP_BASE_URL=https://igochain.vercel.app

# Fallback URL (used if primary has SSL issues)
VITE_APP_FALLBACK_URL=https://igochain.vercel.app

# ============================================
# RESEND EMAIL CONFIGURATION
# ============================================
# Must match the verified domain in Resend dashboard
RESEND_FROM_EMAIL=onboarding@igogroup.in
RESEND_FROM_NAME=IGO Groups
RESEND_API_KEY=your_resend_api_key_here

# ============================================
# SUPABASE EDGE FUNCTION SECRETS
# (Set these in Supabase Dashboard: Edge Functions > Secrets)
# ============================================
# APP_URL=https://igochain.vercel.app
# APP_FALLBACK_URL=https://igochain.vercel.app
# RESEND_API_KEY=your_resend_api_key
# RESEND_FROM_EMAIL=onboarding@igogroup.in
# RESEND_FROM_NAME=IGO Groups

# ============================================
# OPTIONAL: OTHER SERVICES
# ============================================
# VERCEL_TOKEN=your_vercel_token_for_deployments
