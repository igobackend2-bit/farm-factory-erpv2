export function ApprovalChainDisplay({
  approvalStatus,
  boiApprovedBy,
  adminApprovedBy,
  ceoApprovedBy
}: Props) {
  const steps = getMaterialApprovalSteps(approvalStatus);
  
  return (
    <div className="approval-chain">
      {steps.map(step => (
        <StepIndicator
          label={step.role}
          status={step.status}  // 'pending' | 'approved' | 'rejected'
          approvedBy={step.approvedBy}
          timestamp={step.timestamp}
        />
      ))}
    </div>
  );
}
