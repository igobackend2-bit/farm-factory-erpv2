## 🔄 Data Flow & API Architecture

### Core Data Hooks

#### 1. [usePurchaseOrders](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/usePurchaseOrders.ts#53-292) Hook

**File**: [src/hooks/usePurchaseOrders.ts](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/usePurchaseOrders.ts)

**Purpose**: Manage standalone purchase orders

##### API Methods

```typescript
interface UsePurchaseOrdersReturn {
  // State
  purchaseOrders: PurchaseOrder[];
  isLoading: boolean;
  isSaving: boolean;
  
  // Methods
  createPurchaseOrder: (data: CreatePurchaseOrderData) => Promise<{success: boolean}>;
  approvePurchaseOrder: (id: string, role: 'admin' | 'ceo') => Promise<void>;
  rejectPurchaseOrder: (id: string, reason: string) => Promise<void>;
  holdPurchaseOrder: (id: string, reason: string) => Promise<void>;
  resubmitPurchaseOrder: (id: string, data: Partial<CreatePurchaseOrderData>) => Promise<{success: boolean}>;
  refetch: () => Promise<void>;
}
```

##### Real-time Subscriptions

```typescript
// Automatic real-time updates via Supabase channel
useEffect(() => {
  const channel = supabase
    .channel(`purchase-orders-${projectId}`)
    .on('postgres_changes', {
      event: '*',
      schema: 'public',
      table: 'purchase_orders',
      filter: `project_id=eq.${projectId}`
    }, () => {
      fetchPurchaseOrders(); // Auto-refresh on any change
    })
    .subscribe();
  
  return () => supabase.removeChannel(channel);
}, [projectId]);
```

---

#### 2. [useMaterialRequests](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/useMaterialRequests.ts#54-431) Hook

**File**: [src/hooks/useMaterialRequests.ts](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/useMaterialRequests.ts)

**Purpose**: Manage integrated material procurement workflow

##### API Methods

```typescript
interface UseMaterialRequestsReturn {
  // State
  requests: MaterialRequest[];
  isLoading: boolean;
  isSaving: boolean;
  
  // Methods
  createRequest: (data: CreateRequestData) => Promise<void>;
  updateRequest: (id: string, updates: Partial<MaterialRequest>) => Promise<void>;
  assignToPurchase: (id: string, purchaseUserId: string) => Promise<void>;
  selectQuote: (id: string, quoteId: string) => Promise<void>;
  approveRequest: (id: string, role: 'boi' | 'admin' | 'ceo') => Promise<void>;
  createPaymentFromRequest: (requestId: string) => Promise<void>;
  updateDeliveryStatus: (id: string, status: string, notes?: string) => Promise<void>;
  refetch: () => Promise<void>;
}
```

##### Auto-Payment Creation Logic

```typescript
// When CEO approves, automatically create payment request
const approveRequest = async (id: string, role: 'ceo') => {
  // 1. Update approval status
  await supabase
    .from('material_requests')
    .update({ 
      approval_status: 'ceo_approved',
      ceo_approved_by: user.id,
      ceo_approved_at: new Date().toISOString()
    })
    .eq('id', id);
  
  // 2. Auto-create payment request
  await createPaymentFromRequest(id);
};
```

---

#### 3. [useVendorQuotes](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/useVendorQuotes.ts#40-184) Hook

**File**: [src/hooks/useVendorQuotes.ts](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/useVendorQuotes.ts)

**Purpose**: Manage multi-vendor quote comparison

##### API Methods

```typescript
interface UseVendorQuotesReturn {
  // State
  quotes: VendorQuote[];
  isLoading: boolean;
  isSaving: boolean;
  
  // Methods
  addQuote: (data: Omit<VendorQuote, 'id' | 'created_at' | 'created_by' | 'is_selected'>) => Promise<void>;
  selectQuote: (quoteId: string, materialRequestId: string) => Promise<void>;
  deleteQuote: (quoteId: string) => Promise<void>;
  refetch: () => Promise<void>;
}
```

##### Quote Selection Flow

```typescript
const selectQuote = async (quoteId: string, materialRequestId: string) => {
  // Step 1: Deselect all quotes for this request
  await supabase
    .from('vendor_quotes')
    .update({ is_selected: false })
    .eq('material_request_id', materialRequestId);
  
  // Step 2: Select the chosen quote
  await supabase
    .from('vendor_quotes')
    .update({ is_selected: true })
    .eq('id', quoteId);
  
  // Step 3: Update material request & trigger approval flow
  await supabase
    .from('material_requests')
    .update({ 
      selected_quote_id: quoteId,
      approval_status: 'pending_boi'  // Start approval chain
    })
    .eq('id', materialRequestId);
};
```

---

#### 4. [usePurchaseProgress](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/usePurchaseProgress.ts#16-114) Hook

**File**: [src/hooks/usePurchaseProgress.ts](file:///c:/Users/hp/Desktop/igochain-main/src/hooks/usePurchaseProgress.ts)

**Purpose**: Track and log procurement updates

##### API Methods

```typescript
interface UsePurchaseProgressReturn {
  // State
  progressLogs: PurchaseProgressLog[];
  allProgressLogs: PurchaseProgressLog[];
  isLoading: boolean;
  isSaving: boolean;
  
  // Methods
  addProgress: (requestId: string, updateText: string, statusUpdate?: string) => Promise<void>;
  getLatestProgress: (requestId: string) => PurchaseProgressLog | undefined;
  getLogsForRequest: (requestId: string) => PurchaseProgressLog[];
  refetch: () => Promise<void>;
}
```

##### Dual Logging System

```typescript
// Logs to both tables for redundancy & different query patterns
const addProgress = async (requestId: string, updateText: string, statusUpdate?: string) => {
  // Log 1: Real-time updates table
  await supabase.from('purchase_progress_logs').insert({
    material_request_id: requestId,
    update_text: updateText,
    status_update: statusUpdate,
    updated_by: user.id,
    updated_by_name: user.name
  });
  
  // Log 2: Audit trail table
  await supabase.from('procurement_timeline').insert({
    material_request_id: requestId,
    action: 'progress_update',
    performed_by: user.id,
    performed_by_name: user.name,
    details: { update_text: updateText, status_update: statusUpdate }
  });
};
```

