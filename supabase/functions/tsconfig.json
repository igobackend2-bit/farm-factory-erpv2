{
    "compilerOptions": {
        "ignoreDeprecations": "5.0",
        "lib": [
            "esnext"
        ],
        "module": "esnext",
        "target": "esnext",
        "moduleResolution": "bundler",
        "strict": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "types": ["./deno"]
    },
    "exclude": [
        "node_modules",
        ".git"
    ]
}